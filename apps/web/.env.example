# Copy to .env.local and fill in. Same values can be shared with the root .env.

DATABASE_URL=postgresql://quizelo:quizelo@localhost:5432/quizelo
REDIS_URL=redis://localhost:6379

AUTH_SECRET=replace-me-with-32-random-bytes
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

AUTH_APPLE_ID=
AUTH_APPLE_SECRET=

AUTH_RESEND_KEY=
AUTH_EMAIL_FROM=Quizelo <noreply@quizelo.app>

API_URL=http://localhost:4000
# WS_URL is read on the browser side, hence the NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_WS_URL=ws://localhost:4000
