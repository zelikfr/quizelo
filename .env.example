# Copy to .env and fill in. Each app also reads its own .env / .env.local
# (apps/web, apps/api). Values here are inherited by everything via Turbo.

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://quizelo:quizelo@localhost:5432/quizelo
REDIS_URL=redis://localhost:6379

# ─── Auth.js ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-32-random-bytes
# Web origin — used as Auth.js callback URL + default CORS allow.
# Local dev on one machine: http://localhost:3000
# Multi-device on same Wi-Fi: http://<your-lan-ip>:3000
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ─── OAuth providers ─────────────────────────────────────────────
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

AUTH_APPLE_ID=
AUTH_APPLE_SECRET=

# ─── Email magic link (Resend) ───────────────────────────────────
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM=Quizelo <noreply@quizelo.app>

# ─── Match runtime API ───────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000
WS_URL=ws://localhost:4000

# ─── Admin / Backoffice (apps/admin on :3001) ───────────────────
# Admin operators live in the dedicated `admin_users` table — bootstrap
# the first one with:  pnpm --filter @quizelo/admin admin:create
# Shared secret between apps/admin and apps/api for the
# /admin/live-matches endpoint. Generate with `openssl rand -hex 32`.
ADMIN_API_TOKEN=

# ─── Stripe (Premium billing) ────────────────────────────────────
# Server-side secret key (sk_test_… in dev, sk_live_… in prod)
STRIPE_SECRET_KEY=
# Webhook signing secret — copy from `stripe listen` or the dashboard
STRIPE_WEBHOOK_SECRET=
# Price IDs from your Stripe dashboard (Products → Premium → Pricing)
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# ─── Dev: extra CORS origins ─────────────────────────────────────
# Comma-separated. Lets the API accept requests from several origins
# at once — handy when reaching the dev server via both
# `localhost:3000` (your Mac) and `192.168.1.x:3000` (your phone).
# Format: http://host:port[,http://other:port]
# CORS_EXTRA_ORIGINS=http://localhost:3000,http://192.168.1.94:3000
