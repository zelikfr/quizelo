# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://quizelo:quizelo@localhost:5432/quizelo
REDIS_URL=redis://localhost:6379

# ─── Auth.js ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-32-random-bytes
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ─── OAuth providers ─────────────────────────────────────────────
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

AUTH_APPLE_ID=
AUTH_APPLE_SECRET=

# ─── Email magic link (Resend) ───────────────────────────────────
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM=Quizelo <noreply@quizelo.app>

# ─── Match runtime API ───────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000
WS_URL=ws://localhost:4000
